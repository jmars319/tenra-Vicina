{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rally Desktop",
  "version": "0.1.0",
  "identifier": "com.jamarq.rally.desktopapp",
  "build": {
    "beforeDevCommand": "pnpm run dev:webview",
    "beforeBuildCommand": "pnpm run build:webview",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rally Desktop",
        "width": 1200,
        "height": 840,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
