{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vicina by Tenra",
  "version": "0.1.0",
  "identifier": "co.tenra.vicina.desktopapp",
  "build": {
    "beforeDevCommand": "pnpm run dev:webview",
    "beforeBuildCommand": "pnpm run build:webview",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vicina by Tenra",
        "width": 1200,
        "height": 840,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
