{
  "expo": {
    "name": "Vicina",
    "slug": "vicina-mobileapp",
    "scheme": "vicina",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jamarq.vicina.mobileapp"
    },
    "android": {
      "package": "com.jamarq.vicina.mobileapp"
    }
  }
}
